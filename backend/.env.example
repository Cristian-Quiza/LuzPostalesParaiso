# Copia este archivo a .env y rellena con valores reales.
# NUNCA commitees el .env real.

# --- Base de datos ---
USE_POSTGRES=true
# Cadena directa (recomendado). Reemplaza con tu URL real de Supabase / Postgres.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require

# --- Seguridad ---
# Genera uno aleatorio:  python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=cambia-esto-por-uno-aleatorio-largo
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- CORS / orígenes permitidos (separados por coma) ---
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:8001

# --- Modo entorno ---
# production deshabilita /docs y /openapi.json
ENV=development
